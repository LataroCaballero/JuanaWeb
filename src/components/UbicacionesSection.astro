---
import { Image } from 'astro:assets';
import ironManPhoto from '../assets/images/ubicacion-iron-man.jpg';
import caraSurPhoto from '../assets/images/ubicacion-cara-sur.jpg';
---
<section id="ubicaciones" class="bg-surface">
  <div class="grid grid-cols-1 md:grid-cols-2">

    <!-- Iron Man / San Juan -->
    <div class="relative h-[600px] group overflow-hidden">
      <Image
        src={ironManPhoto}
        alt="Iron Man — Del Bono 383 Sur, San Juan"
        class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
        loading="lazy"
      />

      <!-- Electric Blue overlay — cleared on hover to reveal card color -->
      <div class="absolute inset-0 bg-electric/20 mix-blend-multiply group-hover:bg-transparent transition-all duration-700"></div>

      <!-- Bottom text block -->
      <div class="absolute bottom-0 left-0 p-12">
        <!-- Label chip -->
        <span class="bg-black text-white px-4 py-1 text-[11px] font-display font-bold tracking-widest uppercase mb-4 block w-fit">
          CURRENT DOCK
        </span>

        <!-- Card heading -->
        <h3 class="font-display font-bold text-[60px] text-white uppercase leading-none tracking-tighter">
          IRON MAN / SAN JUAN
        </h3>

        <!-- Address -->
        <p class="text-white/80 font-body font-bold mt-4 uppercase tracking-[0.2em] text-[11px]">
          DEL BONO 383 SUR, SAN JUAN, ARGENTINA J5400
        </p>

        <!-- Location CTA per UBIC-03 + D-09 -->
        <a href="https://instagram.com/juana.onyourday"
           target="_blank"
           rel="noopener noreferrer"
           class="text-white/60 font-body text-[11px] uppercase tracking-widest mt-2 block hover:text-electric transition-none">
          Ver dónde estamos hoy
        </a>
      </div>
    </div>

    <!-- Cara Sur / Barreal -->
    <div class="relative h-[600px] group overflow-hidden">
      <Image
        src={caraSurPhoto}
        alt="Cara Sur — Barreal, San Juan"
        class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
        loading="lazy"
      />

      <!-- Electric Blue overlay — cleared on hover to reveal card color -->
      <div class="absolute inset-0 bg-electric/20 mix-blend-multiply group-hover:bg-transparent transition-all duration-700"></div>

      <!-- Bottom text block -->
      <div class="absolute bottom-0 left-0 p-12">
        <!-- Label chip -->
        <span class="bg-black text-white px-4 py-1 text-[11px] font-display font-bold tracking-widest uppercase mb-4 block w-fit">
          MOUNTAIN POST
        </span>

        <!-- Card heading -->
        <h3 class="font-display font-bold text-[60px] text-white uppercase leading-none tracking-tighter">
          CARA SUR / BARREAL
        </h3>

        <!-- Address -->
        <p class="text-white/80 font-body font-bold mt-4 uppercase tracking-[0.2em] text-[11px]">
          BARREAL, SAN JUAN, ARGENTINA
        </p>

        <!-- Location CTA per UBIC-03 + D-09 -->
        <a href="https://instagram.com/juana.onyourday"
           target="_blank"
           rel="noopener noreferrer"
           class="text-white/60 font-body text-[11px] uppercase tracking-widest mt-2 block hover:text-electric transition-none">
          Ver dónde estamos hoy
        </a>
      </div>
    </div>

  </div>
</section>
