---
import { Image } from 'astro:assets';
import historiaTruck from '../assets/images/juana-truck.jpg';
---
<section id="historia" class="bg-surface-low py-32 overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-12 items-center">

    <!-- Image column: 7 of 12 cols -->
    <div class="md:col-span-7 relative">
      <Image
        src={historiaTruck}
        alt="The Juana Truck — TRIBU NOMADE, SIEMPRE EN CASA"
        class="w-full aspect-video object-cover [object-position:center_70%]"
        loading="lazy"
      />

      <!-- "TRIBU NOMADE" floating label — bleeds outside column (do NOT put overflow-hidden on this column) -->
      <div class="absolute -top-12 left-8 bg-electric text-white px-8 py-4 font-display font-bold text-[60px] z-20 uppercase leading-none">
        TRIBU NOMADE
      </div>

      <!-- "SIEMPRE EN CASA." stamp overlays bottom-right of image -->
      <div class="absolute bottom-0 right-0 bg-white text-black p-4 font-display font-bold uppercase text-[11px] tracking-tighter">
        SIEMPRE EN CASA.
      </div>
    </div>

    <!-- Copy column: 5 of 12 cols -->
    <div class="md:col-span-5 p-16 md:p-24 flex flex-col justify-center">
      <!-- Heading: Heading size mobile, Display size desktop -->
      <h2 class="font-display font-bold text-[60px] md:text-8xl tracking-tighter uppercase leading-none mb-8 text-on-surface">
        JUANA TRUCK®
      </h2>

      <!-- Body copy: Spanish brand narrative per D-02 and Copywriting Contract -->
      <p class="font-body text-base text-on-surface/70 mb-12 max-w-sm leading-relaxed">
        Sin paredes fijas. Sin sombras permanentes. Somos un santuario móvil para quienes encuentran el hogar en el movimiento de la calle. TRIBU NOMADE, SIEMPRE EN CASA.
      </p>

      <!-- Editorial divider block -->
      <div class="border-t-4 border-electric pt-8">
        <span class="text-electric text-[11px] font-bold uppercase tracking-widest block mb-2">
          NOW ROAMING
        </span>
        <span class="text-[60px] font-bold italic tracking-tighter font-display text-on-surface leading-none">
          SAN JUAN / BARREAL
        </span>
      </div>

      <!-- Booking CTA -->
      <button
        id="open-booking-modal"
        class="mt-10 bg-electric text-white font-display font-bold text-[13px] uppercase tracking-widest px-8 py-4 hover:bg-white hover:text-black transition-colors duration-200 w-fit"
      >
        RESERVAR EL TRUCK
      </button>
    </div>

  </div>
</section>

<!-- Booking Modal -->
<div
  id="booking-modal"
  class="fixed inset-0 z-[10000] hidden items-center justify-center bg-black/80 p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <div class="bg-surface w-full max-w-lg relative">

    <!-- Header bar -->
    <div class="bg-electric px-8 py-5 flex justify-between items-center">
      <span id="modal-title" class="font-display font-bold text-white uppercase tracking-tighter text-xl">
        RESERVAR EL TRUCK
      </span>
      <button id="close-booking-modal" class="text-white/80 hover:text-white text-2xl leading-none" aria-label="Cerrar">
        ✕
      </button>
    </div>

    <!-- Form -->
    <form
      id="booking-form"
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      class="p-8 flex flex-col gap-6"
    >
      <div class="flex flex-col gap-2">
        <label for="booking-name" class="font-body text-[11px] font-bold uppercase tracking-widest text-on-surface/60">
          Nombre
        </label>
        <input
          id="booking-name"
          type="text"
          name="name"
          required
          placeholder="Tu nombre"
          class="bg-surface-low border border-surface-high text-on-surface font-body text-sm px-4 py-3 placeholder:text-on-surface/30 focus:outline-none focus:border-electric"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label for="booking-email" class="font-body text-[11px] font-bold uppercase tracking-widest text-on-surface/60">
          Email
        </label>
        <input
          id="booking-email"
          type="email"
          name="email"
          required
          placeholder="tu@email.com"
          class="bg-surface-low border border-surface-high text-on-surface font-body text-sm px-4 py-3 placeholder:text-on-surface/30 focus:outline-none focus:border-electric"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label for="booking-message" class="font-body text-[11px] font-bold uppercase tracking-widest text-on-surface/60">
          Descripción del evento
        </label>
        <textarea
          id="booking-message"
          name="message"
          required
          rows="4"
          placeholder="Contanos sobre tu evento — fecha, lugar, cantidad de personas..."
          class="bg-surface-low border border-surface-high text-on-surface font-body text-sm px-4 py-3 placeholder:text-on-surface/30 focus:outline-none focus:border-electric resize-none"
        ></textarea>
      </div>

      <!-- Success / Error messages -->
      <p id="form-success" class="hidden text-electric font-body text-sm font-bold uppercase tracking-widest">
        ¡Mensaje enviado! Te contactamos pronto.
      </p>
      <p id="form-error" class="hidden text-error font-body text-sm font-bold uppercase tracking-widest">
        Algo salió mal. Intentá de nuevo.
      </p>

      <button
        type="submit"
        id="form-submit"
        class="bg-electric text-white font-display font-bold text-[13px] uppercase tracking-widest px-8 py-4 hover:bg-white hover:text-black transition-colors duration-200 mt-2"
      >
        ENVIAR CONSULTA
      </button>
    </form>

  </div>
</div>

<script>
  const modal = document.getElementById('booking-modal')!;
  const openBtn = document.getElementById('open-booking-modal')!;
  const closeBtn = document.getElementById('close-booking-modal')!;
  const form = document.getElementById('booking-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg = document.getElementById('form-error')!;
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement;

  function openModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'ENVIANDO...';
    submitBtn.disabled = true;
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        successMsg.classList.remove('hidden');
        submitBtn.textContent = 'ENVIADO ✓';
      } else {
        errorMsg.classList.remove('hidden');
        submitBtn.textContent = 'ENVIAR CONSULTA';
        submitBtn.disabled = false;
      }
    } catch {
      errorMsg.classList.remove('hidden');
      submitBtn.textContent = 'ENVIAR CONSULTA';
      submitBtn.disabled = false;
    }
  });
</script>
