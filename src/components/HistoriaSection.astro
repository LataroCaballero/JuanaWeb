---
import { Image } from 'astro:assets';
import historiaTruck from '../assets/images/historia-truck.jpg';
---
<section id="historia" class="bg-surface-low py-32 overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-12 items-center">

    <!-- Image column: 7 of 12 cols -->
    <div class="md:col-span-7 relative">
      <Image
        src={historiaTruck}
        alt="The Juana Truck — TRIBU NOMADE, SIEMPRE EN CASA"
        class="w-full aspect-video object-cover"
        loading="lazy"
      />

      <!-- "TRIBU NOMADE" floating label — bleeds outside column (do NOT put overflow-hidden on this column) -->
      <div class="absolute -top-12 -left-12 bg-electric text-white px-8 py-4 font-display font-bold text-[60px] z-20 uppercase leading-none">
        TRIBU NOMADE
      </div>

      <!-- "SIEMPRE EN CASA." stamp overlays bottom-right of image -->
      <div class="absolute bottom-0 right-0 bg-white text-black p-4 font-display font-bold uppercase text-[11px] tracking-tighter">
        SIEMPRE EN CASA.
      </div>
    </div>

    <!-- Copy column: 5 of 12 cols -->
    <div class="md:col-span-5 p-16 md:p-24 flex flex-col justify-center">
      <!-- Heading: Heading size mobile, Display size desktop -->
      <h2 class="font-display font-bold text-[60px] md:text-8xl tracking-tighter uppercase leading-none mb-8 text-on-surface">
        THE JUANA TRUCK®
      </h2>

      <!-- Body copy: Spanish brand narrative per D-02 and Copywriting Contract -->
      <p class="font-body text-base text-on-surface/70 mb-12 max-w-sm leading-relaxed">
        Sin paredes fijas. Sin sombras permanentes. Somos un santuario móvil para quienes encuentran el hogar en el movimiento de la calle. TRIBU NOMADE, SIEMPRE EN CASA.
      </p>

      <!-- Editorial divider block -->
      <div class="border-t-4 border-electric pt-8">
        <span class="text-electric text-[11px] font-bold uppercase tracking-widest block mb-2">
          NOW ROAMING
        </span>
        <span class="text-[60px] font-bold italic tracking-tighter font-display text-on-surface leading-none">
          SAN JUAN / BARREAL
        </span>
      </div>
    </div>

  </div>
</section>
